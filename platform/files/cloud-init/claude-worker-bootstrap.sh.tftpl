#!/bin/bash
# Claude Code worker post-boot bootstrap.
# Driven from the operator machine via SSH; runs as root on the VM (sudo).
# Idempotent — re-running re-applies; every section short-circuits if already done.

set -euo pipefail

echo "==> claude-worker bootstrap starting"

# Architecture detection — release-asset naming differs per project:
#   amd64 host → Go-style 'amd64', uname-style 'x86_64'
#   arm64 host → Go-style 'arm64', uname-style 'aarch64'
ARCH_DPKG=$(dpkg --print-architecture)
case "$ARCH_DPKG" in
  amd64)
    ARCH_GO=amd64          # yq, helm, k9s, ctop, cloudflared (Go release convention)
    ARCH_UNAME=x86_64      # ttyd
    ;;
  arm64)
    ARCH_GO=arm64
    ARCH_UNAME=aarch64
    ;;
  *)
    echo "==> ERROR: unsupported architecture: $ARCH_DPKG" >&2
    exit 1
    ;;
esac
echo "==> arch: $ARCH_DPKG  (Go=$ARCH_GO  uname=$ARCH_UNAME)"

# -----------------------------------------------------------------------------
# Section 1: base packages + tmux defaults + claude-agent user + /workspace mount
# -----------------------------------------------------------------------------
echo "==> [1/?] base packages + users + /workspace"

export DEBIAN_FRONTEND=noninteractive
apt-get update -qq
apt-get install -y -qq \
  build-essential curl wget git gh jq ripgrep fzf bat \
  tmux htop ncdu unzip ca-certificates gnupg lsb-release \
  ufw acl

# yq is in a different repo on Debian — install via mikefarah binary release.
# Distro 'yq' is the Python jq-wrapper, not what we want.
if ! command -v /usr/local/bin/yq >/dev/null 2>&1; then
  curl -sSLo /usr/local/bin/yq \
    "https://github.com/mikefarah/yq/releases/download/v4.44.5/yq_linux_$${ARCH_GO}"
  chmod +x /usr/local/bin/yq
fi

# claude-agent user (no sudo, no shell login by default)
if ! id claude-agent >/dev/null 2>&1; then
  adduser --system --group --shell /bin/bash --home /home/claude-agent claude-agent
  mkdir -p /home/claude-agent/.ssh
  cp /home/${ssh_user}/.ssh/authorized_keys /home/claude-agent/.ssh/authorized_keys
  chown -R claude-agent:claude-agent /home/claude-agent
  chmod 700 /home/claude-agent/.ssh
  chmod 600 /home/claude-agent/.ssh/authorized_keys
fi

# /workspace mount — robust against /dev/sd{a,b} ordering.
# The Proxmox cloud-init template's root disk can land at either sda or sdb
# depending on attach order. We find the data disk by:
#   1. Determining the root disk (the one currently mounted at /)
#   2. Picking whichever other /dev/sd? disk is unformatted (or already
#      carries our workspace label, for idempotent re-runs).
if ! mountpoint -q /workspace; then
  ROOT_DEV=$(findmnt -no SOURCE / | sed 's/[0-9]*$//')   # e.g. /dev/sdb1 → /dev/sdb
  DATA_DEV=""
  # First pass: prefer a disk that already has the workspace label (re-run case).
  # Glob covers both Proxmox SCSI (/dev/sd?) and Incus/KVM virtio (/dev/vd?).
  for cand in /dev/sd? /dev/vd?; do
    [ -b "$cand" ] || continue
    [ "$cand" = "$ROOT_DEV" ] && continue
    if blkid -t LABEL=workspace "$cand" >/dev/null 2>&1; then
      DATA_DEV="$cand"
      break
    fi
  done
  # Second pass: any other disk that has no filesystem yet
  if [ -z "$DATA_DEV" ]; then
    for cand in /dev/sd? /dev/vd?; do
      [ -b "$cand" ] || continue
      [ "$cand" = "$ROOT_DEV" ] && continue
      [ "$(blockdev --getsize64 "$cand" 2>/dev/null || echo 0)" -lt 1000000000 ] && continue   # skip < 1 GB
      if ! blkid "$cand" >/dev/null 2>&1; then
        DATA_DEV="$cand"
        break
      fi
    done
  fi
  if [ -z "$DATA_DEV" ]; then
    echo "==> ERROR: couldn't find a non-root data disk for /workspace (root=$ROOT_DEV)" >&2
    lsblk
    exit 1
  fi
  if ! blkid -t LABEL=workspace "$DATA_DEV" >/dev/null 2>&1; then
    mkfs.ext4 -F -L workspace "$DATA_DEV"
  fi
  mkdir -p /workspace
  # Drop any stale/broken LABEL=workspace entry that an earlier failed run added,
  # then write the canonical one. Use `nofail` so a future boot with the data
  # disk missing doesn't hang systemd in emergency mode.
  sed -i '\|LABEL=workspace /workspace|d' /etc/fstab
  echo "LABEL=workspace /workspace ext4 defaults,nofail,noatime 0 2" >> /etc/fstab
  systemctl daemon-reload
  mount /workspace
fi
# Group-writable, sgid so new files inherit group
chown claude-agent:${ssh_user} /workspace
chmod 2775 /workspace
mkdir -p /workspace/${ssh_user} /workspace/claude-agent /workspace/agent-jobs /workspace/shared
chown ${ssh_user}:${ssh_user}           /workspace/${ssh_user}
chown claude-agent:claude-agent         /workspace/claude-agent
chown claude-agent:claude-agent         /workspace/agent-jobs
chown ${ssh_user}:${ssh_user}           /workspace/shared

# tmux auto-attach on login (only for interactive SSH/ttyd, not cron)
cat > /etc/profile.d/00-tmux-attach.sh <<'EOF'
# Auto-attach interactive shells to the shared 'main' tmux session.
if command -v tmux >/dev/null 2>&1 && [ -n "$SSH_TTY" ] && [ -z "$TMUX" ] && [ "$TERM" != "dumb" ]; then
  tmux new-session -A -s main
fi
EOF
chmod +x /etc/profile.d/00-tmux-attach.sh

# Tmux config — vi copy mode, hjkl pane nav, Catppuccin Mocha status bar
# with hostname / session / k8s-context / load / time. True-color through SSH.
cat > /etc/skel/.tmux.conf <<'EOF'
# ── core ───────────────────────────────────────────────────────────────
set -g mouse on
set -g history-limit 100000
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g focus-events on
set -sg escape-time 10
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",xterm-256color:Tc"

# vi-style copy mode
setw -g mode-keys vi
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi y send-keys -X copy-selection-and-cancel

# ── pane / window keys ─────────────────────────────────────────────────
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"
bind c new-window      -c "#{pane_current_path}"
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5
bind r source-file ~/.tmux.conf \; display "tmux.conf reloaded"

# ── status bar (high-contrast, designed for pure-black terminal bg) ────
# Status-bar bg is a mid-dark gray (#3a3a3a) so it's clearly distinct from
# a black terminal, with bright primary-color accents for legibility.
# Active window has a gold highlight that genuinely pops.
set -g status-interval 5
set -g status-position bottom
set -g status-justify left
set -g status-style "bg=#3a3a3a,fg=#e4e4e4"
set -g status-left-length 40
set -g status-right-length 120
# Hostname (bright cyan), session (bright green), separators (medium gray)
set -g status-left  "#[fg=#5fd7ff,bold] #h #[fg=#767676]│#[fg=#5fff5f,bold] #S #[fg=#767676]│ "
# k8s context (orange), load avg (bright yellow), date+time (pure white)
set -g status-right "#[fg=#ff8700]k8s:#(kubectl config current-context 2>/dev/null || echo none) #[fg=#767676]│#[fg=#ffff5f] load:#(cut -d' ' -f1-3 /proc/loadavg) #[fg=#767676]│#[fg=#ffffff,bold] %a %H:%M "
# Active window: black on gold (high contrast); inactive: subtle gray
setw -g window-status-current-style "fg=#000000,bg=#ffd700,bold"
setw -g window-status-current-format " #I:#W "
setw -g window-status-style          "fg=#b0b0b0"
setw -g window-status-format         " #I:#W "
set -g pane-border-style        "fg=#5f5f5f"
set -g pane-active-border-style "fg=#5fd7ff"
# Message line (e.g., 'tmux.conf reloaded'): high-contrast yellow on black
set -g message-style            "fg=#000000,bg=#ffd700,bold"

# Click on the left status segment (hostname / session name) → open a
# flat session picker. We use display-menu (via a tiny wrapper script)
# instead of choose-tree because choose-tree always tracks a "selected
# window" target internally — even in -s sessions-only mode — so
# clicking what looks like the session row can switch to a child window
# (most recently 'cheats') rather than to the session's current window.
# display-menu lists session names and only session names; selecting one
# runs switch-client -t SESSION cleanly.
bind -n MouseDown1StatusLeft run-shell "/usr/local/bin/tmux-session-menu"
EOF
for u in ${ssh_user} claude-agent; do
  cp /etc/skel/.tmux.conf /home/$u/.tmux.conf
  chown $u:$u /home/$u/.tmux.conf
done

# -----------------------------------------------------------------------------
# Section 2: Docker Engine + Compose v2 (from Docker's apt repo, not Debian's)
# -----------------------------------------------------------------------------
echo "==> [2/?] Docker Engine + Compose v2"

if ! command -v docker >/dev/null 2>&1; then
  install -m 0755 -d /etc/apt/keyrings
  curl -fsSL https://download.docker.com/linux/debian/gpg \
    | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  chmod a+r /etc/apt/keyrings/docker.gpg
  echo \
    "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] \
     https://download.docker.com/linux/debian $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
    > /etc/apt/sources.list.d/docker.list
  apt-get update -qq
  apt-get install -y -qq docker-ce docker-ce-cli containerd.io \
    docker-buildx-plugin docker-compose-plugin
fi

# Both users in docker group (no need for sudo to run docker)
usermod -aG docker ${ssh_user} || true
usermod -aG docker claude-agent || true

systemctl enable --now docker

# oxker — Rust/ratatui Docker TUI for the dashboard 'docker' window.
# Picked over lazydocker (which leaked thousands of UNIX sockets into dockerd
# via its short-lived polling pattern) and over ctop (unmaintained since 2022,
# uses termbox so it panics on tmux-256color TERM, and a Go SDK that opens a
# new HTTP connection per refresh). oxker uses Bollard's persistent streaming
# connections (5 long-lived sockets vs ctop's per-refresh churn), holds a
# steady ~7 MB RSS and 0.3 % CPU, and runs cleanly in tmux without TERM hacks.
# Trade-off accepted: no block-IO column — but neither ctop nor dtop nor oxker
# read cgroup-v2 io.stat (the field is only in Docker's new structured stats
# response; legacy BlkioStats stays empty on v2). Use `docker stats` ad-hoc
# if you need IO numbers.
OXKER_VER="0.13.2"
case "$ARCH_DPKG" in
  amd64) OXKER_ASSET="oxker_linux_x86_64.tar.gz" ;;
  arm64) OXKER_ASSET="oxker_linux_aarch64.tar.gz" ;;
esac
if [ ! -x /usr/local/bin/oxker ] \
   || ! /usr/local/bin/oxker --version 2>&1 | grep -q "$OXKER_VER"; then
  curl -fsSL "https://github.com/mrjackwills/oxker/releases/download/v$${OXKER_VER}/$${OXKER_ASSET}" \
    | tar -xz -C /tmp oxker
  install -m 0755 /tmp/oxker /usr/local/bin/oxker
  rm -f /tmp/oxker
fi

# oxker uses its stock colors — no config drop here. If you want to
# override, drop a TOML at ~/.config/oxker/config.toml (per-user) or pass
# --config-file <path> in the dashboard launcher.

# -----------------------------------------------------------------------------
# Section 2.5: Relocate Docker + containerd state to /workspace, add log rotation
# Root disk is 16 GB; buildx snapshots and overlayfs layers can easily exceed
# that, while /workspace (48 GB) sits mostly empty. Bind-mount via fstab so it
# survives reboot. Idempotent — once the binds are active, re-runs are a no-op.
# -----------------------------------------------------------------------------
echo "==> [2.5/?] relocate /var/lib/{docker,containerd} to /workspace + log rotation"

mountpoint -q /workspace || { echo "ERROR: /workspace not mounted" >&2; exit 1; }

if mountpoint -q /var/lib/docker && mountpoint -q /var/lib/containerd; then
  echo "    (docker + containerd already on /workspace binds)"
else
  # Free obvious cache first so the cross-FS move has slack on the tight root.
  if systemctl is-active --quiet docker; then
    docker buildx prune -af 2>/dev/null || true
    systemctl stop docker.socket docker containerd
  fi

  relocate_to_workspace() {
    local src="$1"          # e.g. /var/lib/docker
    local dst="/workspace/$2"

    mountpoint -q "$src" && return 0
    mkdir -p "$dst" "$src"

    # First run only: move existing data across. cp -a preserves owner/perms/xattrs.
    if [ -n "$(find "$src" -mindepth 1 -maxdepth 1 -print -quit 2>/dev/null)" ]; then
      cp -a "$src"/. "$dst"/
      find "$src" -mindepth 1 -maxdepth 1 -exec rm -rf {} +
    fi

    grep -qE "^[^#]*[[:space:]]$src[[:space:]]" /etc/fstab \
      || echo "$dst $src none bind,nofail 0 0" >> /etc/fstab
    systemctl daemon-reload
    mount "$src"
  }

  relocate_to_workspace /var/lib/docker      var-lib-docker
  relocate_to_workspace /var/lib/containerd  var-lib-containerd
fi

# Log rotation for new container logs. Existing files aren't rotated
# retroactively — they age out as containers are recreated.
install -d -m 0755 /etc/docker
cat > /etc/docker/daemon.json <<'EOF'
{
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "10m",
    "max-file": "3"
  }
}
EOF

# Restart docker so daemon.json + the relocated data-root take effect.
# Section 2 already enabled the unit, so we just need it active.
systemctl is-active --quiet docker || systemctl start docker

# -----------------------------------------------------------------------------
# Section 2.6: dockerd memory safety
# Caps dockerd RSS so a leaked daemon (seen with stuck healthchecks / crash
# loops in long-running compose stacks) gets OOM-killed cleanly and systemd
# restarts it — instead of dragging the whole 8 GiB VM into swap-thrash where
# even sshd can't fork. Containerd survives dockerd restarts; running
# containers reattach. Also schedules a weekly preventive restart so the
# leak never accumulates past one week of uptime.
# -----------------------------------------------------------------------------
echo "==> [2.6/?] dockerd memory cap + weekly preventive restart"

install -d /etc/systemd/system/docker.service.d
cat > /etc/systemd/system/docker.service.d/memory-cap.conf <<'EOF'
[Service]
MemoryMax=2000M
MemoryHigh=1700M
EOF

cat > /etc/systemd/system/docker-weekly-restart.service <<'EOF'
[Unit]
Description=Weekly preventive restart of dockerd (mitigate slow memory growth)
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
ExecStart=/bin/systemctl restart docker.service
EOF
cat > /etc/systemd/system/docker-weekly-restart.timer <<'EOF'
[Unit]
Description=Trigger weekly preventive docker restart

[Timer]
OnCalendar=Sun 04:00:00
Persistent=true
Unit=docker-weekly-restart.service

[Install]
WantedBy=timers.target
EOF

systemctl daemon-reload
systemctl enable --now docker-weekly-restart.timer
# Reload docker so the new MemoryMax takes effect (a no-op if it's already
# under the limit and starting from a fresh bootstrap).
systemctl restart docker

# -----------------------------------------------------------------------------
# Section 3: Node.js 20 LTS + Claude Code CLI (per-user, no sudo npm)
# -----------------------------------------------------------------------------
echo "==> [3/?] Node.js + Claude Code"

if ! command -v node >/dev/null 2>&1 || [ "$(node --version | cut -d. -f1 | tr -d v)" -lt 18 ]; then
  # Prefer NodeSource 20.x; fall back to distro nodejs+npm if NodeSource is
  # unreachable (Cloudflare-edge timeouts have been observed from some networks).
  if curl -fsSL --max-time 20 https://deb.nodesource.com/setup_20.x -o /tmp/nodesource.sh && bash /tmp/nodesource.sh && apt-get install -y -qq nodejs; then
    rm -f /tmp/nodesource.sh
  else
    echo "    (NodeSource unreachable — using distro nodejs + npm)"
    rm -f /tmp/nodesource.sh /etc/apt/sources.list.d/nodesource.* /usr/share/keyrings/nodesource.gpg
    apt-get update -qq
    apt-get install -y -qq nodejs npm
  fi
fi
# Some distro nodejs packages ship without npm (Debian 12). Ensure both present.
command -v npm >/dev/null 2>&1 || apt-get install -y -qq npm

# Per-user global npm prefix so 'npm install -g' works without sudo
install_claude_code_for() {
  local user=$1
  local home
  home=$(getent passwd "$user" | cut -d: -f6)
  sudo -u "$user" mkdir -p "$home/.npm-global"
  sudo -u "$user" npm config set prefix "$home/.npm-global"
  if ! sudo -u "$user" "$home/.npm-global/bin/claude" --version >/dev/null 2>&1; then
    sudo -u "$user" npm install -g @anthropic-ai/claude-code
  fi
  # PATH update in user's ~/.bashrc (idempotent grep guard)
  if ! grep -qF '.npm-global/bin' "$home/.bashrc" 2>/dev/null; then
    echo 'export PATH="$HOME/.npm-global/bin:$PATH"' >> "$home/.bashrc"
  fi
}

install_claude_code_for ${ssh_user}
install_claude_code_for claude-agent

# Shared OAuth: c4's interactive shells read claude-agent's credentials
cat > /etc/profile.d/01-claude-shared-oauth.sh <<'EOF'
# Both users share one OAuth token, owned by claude-agent.
# For c4's interactive shells: point CLAUDE_HOME at claude-agent's dir.
# claude-agent's own shells use their default ~/.claude (no override needed).
if [ "$USER" = "__SSH_USER__" ]; then
  export CLAUDE_HOME=/home/claude-agent/.claude
fi
EOF
# Substitute the user name into the file (the heredoc is single-quoted so $USER stays)
sed -i "s/__SSH_USER__/${ssh_user}/" /etc/profile.d/01-claude-shared-oauth.sh
chmod +x /etc/profile.d/01-claude-shared-oauth.sh

# Grant c4 read access to claude-agent's .claude dir (defaults so future files
# inside .claude inherit). claude-agent stays the owner; c4 is the secondary
# group on the .claude tree.
sudo -u claude-agent mkdir -p /home/claude-agent/.claude
chgrp -R ${ssh_user} /home/claude-agent/.claude
chmod 750 /home/claude-agent /home/claude-agent/.claude
setfacl -R -m g:${ssh_user}:rx /home/claude-agent/.claude
setfacl -R -d -m g:${ssh_user}:rx /home/claude-agent/.claude

# -----------------------------------------------------------------------------
# Section 4: language toolchains (Python, Go, Rust)
# -----------------------------------------------------------------------------
echo "==> [4/?] Python + Go + Rust"

apt-get install -y -qq python3 python3-venv python3-pip pipx golang-go

# Rust to /opt/rust (shared, both users PATH'd to /opt/rust/cargo/bin)
if [ ! -x /opt/rust/cargo/bin/cargo ]; then
  mkdir -p /opt/rust
  export RUSTUP_HOME=/opt/rust/rustup
  export CARGO_HOME=/opt/rust/cargo
  curl -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path --default-toolchain stable
  chmod -R go+rX /opt/rust
fi

cat > /etc/profile.d/02-rust-path.sh <<'EOF'
export RUSTUP_HOME=/opt/rust/rustup
export CARGO_HOME=/opt/rust/cargo
export PATH="$CARGO_HOME/bin:$PATH"
EOF
chmod +x /etc/profile.d/02-rust-path.sh

# -----------------------------------------------------------------------------
# Section 5: k8s tooling (kubectl, helm, k9s)
# -----------------------------------------------------------------------------
echo "==> [5/?] kubectl + helm + k9s"

K8S_MINOR="1.30"
if ! command -v kubectl >/dev/null 2>&1; then
  curl -fsSL "https://pkgs.k8s.io/core:/stable:/v$${K8S_MINOR}/deb/Release.key" \
    | gpg --dearmor -o /etc/apt/keyrings/kubernetes-apt-keyring.gpg
  echo "deb [signed-by=/etc/apt/keyrings/kubernetes-apt-keyring.gpg] https://pkgs.k8s.io/core:/stable:/v$${K8S_MINOR}/deb/ /" \
    > /etc/apt/sources.list.d/kubernetes.list
  apt-get update -qq
  apt-get install -y -qq kubectl
fi

# helm — direct tarball from get.helm.sh (avoids baltocdn.com which is
# unreachable from some networks, including this homelab's egress).
# Clean up any leftover baltocdn apt config from a previous failed run.
rm -f /etc/apt/keyrings/helm.gpg /etc/apt/sources.list.d/helm-stable-debian.list
HELM_VER="v3.16.3"
if [ ! -x /usr/local/bin/helm ] || ! /usr/local/bin/helm version --short 2>/dev/null | grep -q "$HELM_VER"; then
  rm -rf /tmp/helm-extract && mkdir -p /tmp/helm-extract
  curl -fsSL "https://get.helm.sh/helm-$${HELM_VER}-linux-$${ARCH_GO}.tar.gz" \
    | tar -xz -C /tmp/helm-extract
  install -m 0755 "/tmp/helm-extract/linux-$${ARCH_GO}/helm" /usr/local/bin/helm
  rm -rf /tmp/helm-extract
fi

# k9s — Debian doesn't have it; install from upstream release tarball
K9S_VER="v0.32.5"
if [ ! -x /usr/local/bin/k9s ] || ! /usr/local/bin/k9s version 2>/dev/null | grep -q "$K9S_VER"; then
  curl -fsSL "https://github.com/derailed/k9s/releases/download/$K9S_VER/k9s_Linux_$${ARCH_GO}.tar.gz" \
    | tar -xz -C /tmp k9s
  install -m 0755 /tmp/k9s /usr/local/bin/k9s
  rm -f /tmp/k9s
fi

# /etc/skel/.kube placeholder so future users get the directory; the actual
# kubeconfig is dropped by Terraform in a follow-up null_resource.
install -d -m 0755 /etc/skel/.kube
for u in ${ssh_user} claude-agent; do
  install -d -m 0700 -o "$u" -g "$u" /home/$u/.kube
done

# -----------------------------------------------------------------------------
# Section 6: web terminal (ttyd) + Caddy reverse proxy for LAN HTTPS
# -----------------------------------------------------------------------------
echo "==> [6/?] ttyd + Caddy"

TTYD_VER="1.7.7"
if [ ! -x /usr/local/bin/ttyd ] || ! /usr/local/bin/ttyd --version 2>&1 | grep -q "$TTYD_VER"; then
  curl -fsSL "https://github.com/tsl0922/ttyd/releases/download/$TTYD_VER/ttyd.$${ARCH_UNAME}" \
    -o /usr/local/bin/ttyd
  chmod +x /usr/local/bin/ttyd
fi

# systemd unit — runs as claude-agent, spawns tmux attach into the shared session.
cat > /etc/systemd/system/ttyd.service <<'EOF'
[Unit]
Description=ttyd web terminal (drops to claude-agent, attaches shared tmux)
After=network.target

[Service]
Type=simple
User=claude-agent
Group=claude-agent
ExecStart=/usr/local/bin/ttyd -i 127.0.0.1 -p 7681 -t titleFixed='claude-worker' tmux new-session -A -s main
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
EOF

# Caddy via apt (cloudsmith repo)
if ! command -v caddy >/dev/null 2>&1; then
  curl -fsSL https://dl.cloudsmith.io/public/caddy/stable/gpg.key | gpg --dearmor -o /etc/apt/keyrings/caddy-stable.gpg
  curl -fsSL https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt \
    | sed 's|/usr/share/keyrings|/etc/apt/keyrings|; s|caddy-stable-archive-keyring|caddy-stable|' \
    > /etc/apt/sources.list.d/caddy-stable.list
  apt-get update -qq
  apt-get install -y -qq caddy
fi

# Detect hostname + primary IP so Caddy can issue a local-CA leaf cert with
# both as SANs. With just `:443 { tls internal }`, Caddy generates no cert
# when the client connects by IP (no matching hostname) and the browser
# fails with ERR_SSL_PROTOCOL_ERROR.
CADDY_HOSTNAME=$(hostname)
CADDY_PRIMARY_IP=$(hostname -I 2>/dev/null | awk '{print $1}')
cat > /etc/caddy/Caddyfile <<EOF
# Caddy in front of ttyd. tls internal = self-signed via Caddy's local CA;
# browser will show a "not secure" warning on first visit (trust-on-first-use).
# Public access goes through CF Tunnel + CF Access at claude.chifor.dev with a
# properly-trusted cert from Cloudflare's edge.
{
  local_certs
}
https://$${CADDY_PRIMARY_IP}, https://$${CADDY_HOSTNAME} {
  tls internal
  reverse_proxy 127.0.0.1:7681
}
:80 {
  redir https://{host}{uri} permanent
}
EOF

systemctl daemon-reload
systemctl enable --now ttyd.service caddy.service
systemctl reload caddy 2>/dev/null || systemctl restart caddy

# -----------------------------------------------------------------------------
# Section 7: cloudflared (only if tunnel token provided)
# -----------------------------------------------------------------------------
echo "==> [7/?] cloudflared"

CF_TUNNEL_TOKEN='${cf_tunnel_token}'

if [ -z "$CF_TUNNEL_TOKEN" ]; then
  echo "    (no CF tunnel token configured — skipping cloudflared install)"
else
  if ! command -v cloudflared >/dev/null 2>&1; then
    curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg \
      -o /etc/apt/keyrings/cloudflare-main.gpg
    echo "deb [signed-by=/etc/apt/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared $(. /etc/os-release && echo "$VERSION_CODENAME") main" \
      > /etc/apt/sources.list.d/cloudflared.list
    apt-get update -qq
    apt-get install -y -qq cloudflared
  fi
  # cloudflared service install with the token
  cloudflared service install "$CF_TUNNEL_TOKEN" 2>&1 | grep -v -i 'already installed' || true
  systemctl enable --now cloudflared
fi

# -----------------------------------------------------------------------------
# Section 8: ufw firewall (LAN-only inbound; cloudflared connects outbound)
# -----------------------------------------------------------------------------
echo "==> [8/?] ufw"

# Reset to a known state on first run, then declare desired rules
if [ "$(ufw status | head -1)" != "Status: active" ]; then
  ufw --force reset >/dev/null
  ufw default deny incoming
  ufw default allow outgoing
  ufw allow from 192.168.0.0/24 to any port 22 proto tcp comment 'SSH from LAN'
  ufw allow from 192.168.0.0/24 to any port 443 proto tcp comment 'Caddy HTTPS from LAN'
  ufw allow from 192.168.0.0/24 to any port 80 proto tcp comment 'Caddy HTTP redirect from LAN'
  ufw --force enable
fi

# -----------------------------------------------------------------------------
# Section 9: claude-grant-write helper (opt-in RW kubeconfig)
# -----------------------------------------------------------------------------
echo "==> [9/?] claude-grant-write"

cat > /usr/local/bin/claude-grant-write <<'EOF'
#!/bin/bash
# Opt-in escalation: switch the current shell's KUBECONFIG to the RW config.
# The RW config is root-readable only — accessing it requires sudo, which
# means the operator has to type their password. Even an agent prompt that
# 'bash -c's its way out cannot reach edit-level RBAC without that password.

set -euo pipefail
RW=/etc/claude-agent/kube-rw-config

if [ ! -r "$RW" ]; then
  if ! sudo test -r "$RW"; then
    echo "claude-grant-write: $RW does not exist yet. Has Terraform fetched the RW kubeconfig?" >&2
    exit 1
  fi
  # Stage a per-user readable copy under /run (tmpfs, ephemeral)
  STAGED="/run/user/$(id -u)/kube-rw-config"
  install -d -m 0700 "$(dirname "$STAGED")"
  sudo install -m 0400 -o "$(id -u)" -g "$(id -g)" "$RW" "$STAGED"
else
  STAGED="$RW"
fi

echo "claude-grant-write: KUBECONFIG=$STAGED exported for this shell."
echo "  - kubectl now has edit-level RBAC against the cluster."
echo "  - 'exit' or open a new shell to drop back to read-only."
exec env KUBECONFIG="$STAGED" "$SHELL"
EOF
chmod 0755 /usr/local/bin/claude-grant-write

# -----------------------------------------------------------------------------
# Section 10: systemd timer template + example agent-job skeletons
# -----------------------------------------------------------------------------
echo "==> [10/?] claude-job systemd template + examples"

# Parameterised service template; one instance per job name
cat > /etc/systemd/system/claude-job@.service <<'EOF'
[Unit]
Description=Claude Code headless job (%i)
After=network-online.target

[Service]
Type=oneshot
User=claude-agent
Group=claude-agent
WorkingDirectory=/workspace/agent-jobs/%i
EnvironmentFile=-/workspace/agent-jobs/%i/job.env
# Pin OAuth credential path explicitly (cron doesn't load /etc/profile.d)
Environment=CLAUDE_HOME=/home/claude-agent/.claude
Environment=PATH=/home/claude-agent/.npm-global/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
ExecStart=/bin/bash -c 'mkdir -p output && claude -p "$$(cat prompt.md)" --output-format json --allowed-tools "$$(cat allowed-tools.txt | tr "\n" "," | sed s/,$$//)" >> output/$$(date -u +%%Y%%m%%dT%%H%%M%%SZ).jsonl 2>&1'
TimeoutStartSec=30min
EOF

# Example job 1: longhorn-health (every 6 hours)
install -d -o claude-agent -g claude-agent /workspace/agent-jobs/longhorn-health/output
cat > /workspace/agent-jobs/longhorn-health/prompt.md <<'EOF'
You are an SRE assistant for a home-lab k3s cluster. Read the current
Longhorn state via kubectl (your kubeconfig is read-only). Produce a
concise health summary as Markdown: total volumes, attached vs detached,
any volumes with degraded replicas, any nodes with disk pressure, any
recent BackupTarget errors. Write the summary to
/workspace/agent-jobs/longhorn-health/output/summary-$(date +%F).md.
EOF
cat > /workspace/agent-jobs/longhorn-health/allowed-tools.txt <<'EOF'
Bash(kubectl get *)
Bash(kubectl describe *)
Bash(kubectl logs *)
Bash(date *)
Write
EOF
cat > /workspace/agent-jobs/longhorn-health/job.env <<'EOF'
EOF
cat > /etc/systemd/system/claude-job@longhorn-health.timer <<'EOF'
[Unit]
Description=Claude Code longhorn-health every 6h

[Timer]
OnBootSec=15min
OnUnitActiveSec=6h
Unit=claude-job@longhorn-health.service

[Install]
WantedBy=timers.target
EOF
chown -R claude-agent:claude-agent /workspace/agent-jobs/longhorn-health

# Example job 2: nightly-repo-audit (02:00 daily). Disabled until you fill in
# the repo list in prompt.md / job.env.
install -d -o claude-agent -g claude-agent /workspace/agent-jobs/nightly-repo-audit/output
cat > /workspace/agent-jobs/nightly-repo-audit/prompt.md <<'EOF'
You are a code-review assistant. Read $REPO_LIST (one git URL per line, from
job.env). For each repo, clone if missing under /workspace/agent-jobs/nightly-repo-audit/repos/,
then 'git pull'. Run a focused review on commits since the last summary
(stored at output/last-reviewed.txt): look for security issues, broken
tests, TODOs without owners. Write findings to
output/audit-$(date +%F).md.
EOF
cat > /workspace/agent-jobs/nightly-repo-audit/allowed-tools.txt <<'EOF'
Bash(git *)
Bash(date *)
Bash(ls *)
Read
Write
Grep
EOF
cat > /workspace/agent-jobs/nightly-repo-audit/job.env <<'EOF'
# Populate REPO_LIST with newline-separated git URLs to enable this job.
REPO_LIST="
"
EOF
cat > /etc/systemd/system/claude-job@nightly-repo-audit.timer <<'EOF'
[Unit]
Description=Claude Code nightly repo audit at 02:00

[Timer]
OnCalendar=*-*-* 02:00:00
Persistent=true
Unit=claude-job@nightly-repo-audit.service

[Install]
WantedBy=timers.target
EOF
chown -R claude-agent:claude-agent /workspace/agent-jobs/nightly-repo-audit

systemctl daemon-reload
# Enable the timers but DON'T start nightly-repo-audit until the operator has
# populated REPO_LIST. longhorn-health is safe to start (it just reads).
systemctl enable --now claude-job@longhorn-health.timer
systemctl enable claude-job@nightly-repo-audit.timer
# Stop the nightly-repo-audit timer until configured
systemctl stop  claude-job@nightly-repo-audit.timer || true

# -----------------------------------------------------------------------------
# Section 11: restic backup to MinIO (off-host)
# -----------------------------------------------------------------------------
echo "==> [11/?] restic"

RESTIC_REPO='${restic_repo_url}'
RESTIC_PASSWORD='${restic_password}'

if [ -z "$RESTIC_PASSWORD" ]; then
  echo "    (no restic password configured — skipping restic install)"
else
  if ! command -v restic >/dev/null 2>&1; then
    apt-get install -y -qq restic
  fi

  install -d -m 0700 /etc/restic
  echo "$RESTIC_PASSWORD" > /etc/restic/repo.key
  chmod 0600 /etc/restic/repo.key
  cat > /etc/restic/env <<EOF
export RESTIC_REPOSITORY="$RESTIC_REPO"
export RESTIC_PASSWORD_FILE=/etc/restic/repo.key
# AWS_* creds for MinIO (S3-compatible). The NAS LXC's MinIO root user
# is fine for a single-tenant homelab; tighten with a scoped user later.
export AWS_ACCESS_KEY_ID="\$(cat /etc/restic/minio-access)"
export AWS_SECRET_ACCESS_KEY="\$(cat /etc/restic/minio-secret)"
EOF
  chmod 0600 /etc/restic/env

  # Initialize repo if absent (probes via 'restic snapshots' — failure = uninit)
  if ! ( . /etc/restic/env && restic snapshots >/dev/null 2>&1 ); then
    ( . /etc/restic/env && restic init ) || echo "    (restic init failed — likely missing MinIO creds; finish setup per module README)"
  fi

  # Backup unit + timer
  cat > /etc/systemd/system/restic-backup.service <<'EOF'
[Unit]
Description=restic backup to MinIO

[Service]
Type=oneshot
EnvironmentFile=/etc/restic/env
ExecStart=/usr/bin/restic backup --quiet \
  --exclude /workspace/agent-jobs/*/repos \
  --exclude /home/*/.cache \
  --exclude /var/lib/docker \
  /workspace /home /etc/cloudflared /etc/claude-agent
ExecStartPost=/usr/bin/restic forget --quiet --prune \
  --keep-daily 7 --keep-weekly 4 --keep-monthly 6
EOF
  cat > /etc/systemd/system/restic-backup.timer <<'EOF'
[Unit]
Description=Daily restic backup

[Timer]
OnCalendar=*-*-* 04:00:00
Persistent=true
Unit=restic-backup.service

[Install]
WantedBy=timers.target
EOF
  systemctl daemon-reload
  systemctl enable --now restic-backup.timer
fi

# -----------------------------------------------------------------------------
# Section 12: claude-run dispatcher (SSH-triggered ad-hoc job runs)
# -----------------------------------------------------------------------------
echo "==> [12/?] claude-run"

cat > /usr/local/bin/claude-run <<'EOF'
#!/bin/bash
# Trigger an agent job by name. Usage: claude-run <job-name> [extra prompt arg]
# Reads /workspace/agent-jobs/<job-name>/{prompt.md, allowed-tools.txt, job.env}.
# Output is captured to /workspace/agent-jobs/<job-name>/output/<timestamp>.jsonl
# and tailed back to the caller in real time.

set -euo pipefail
JOB="$${1:-}"
[ -z "$JOB" ] && { echo "usage: claude-run <job-name> [extra-prompt]" >&2; exit 1; }
DIR="/workspace/agent-jobs/$JOB"
[ -d "$DIR" ] || { echo "claude-run: $DIR does not exist" >&2; exit 1; }

# Run the same systemd unit pattern as the timer so behaviour is identical
exec sudo systemctl start --wait "claude-job@$${JOB}.service"
EOF
chmod 0755 /usr/local/bin/claude-run

# Sudoer rule allowing c4 + claude-agent to start claude-job@*.service WITHOUT
# password — but only those units, nothing else
cat > /etc/sudoers.d/claude-job-trigger <<EOF
${ssh_user} ALL=(root) NOPASSWD: /bin/systemctl start --wait claude-job@*.service
${ssh_user} ALL=(root) NOPASSWD: /bin/systemctl start claude-job@*.service
EOF
chmod 0440 /etc/sudoers.d/claude-job-trigger

# -----------------------------------------------------------------------------
# Section 13: SSH password auth for c4 (optional, controlled by c4_password var)
# -----------------------------------------------------------------------------
# Default sshd_config on Debian cloud images is pubkey-only. That's the
# right posture for headless agents, but blocks clients like KiTTY whose
# default profile doesn't auto-load ~/.ssh/id_ed25519. When the operator
# sets TF_VAR_claude_worker_c4_password, we set the c4 password and enable
# PasswordAuthentication so those clients work alongside pubkey.
echo "==> [13/?] ssh password auth (optional)"

C4_PASSWORD='${c4_password}'

if [ -n "$C4_PASSWORD" ]; then
  # chpasswd is idempotent — running with the same plaintext just re-hashes
  echo "c4:$C4_PASSWORD" | chpasswd
  # Enable PasswordAuthentication in the main config + any drop-ins
  sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' /etc/ssh/sshd_config
  for f in /etc/ssh/sshd_config.d/*.conf; do
    [ -f "$f" ] && sed -i 's/^#\?PasswordAuthentication.*/PasswordAuthentication yes/' "$f"
  done
  # Make sure at least one config layer has the explicit line (drop-ins may
  # not have the directive at all). Write a small standalone drop-in.
  cat > /etc/ssh/sshd_config.d/10-claude-worker-passwordauth.conf <<EOF
PasswordAuthentication yes
EOF
  systemctl reload ssh
  echo "    PasswordAuthentication enabled for c4"
else
  # Operator hasn't opted in — leave the cloud-init pubkey-only default alone.
  echo "    (no c4 password configured — keeping pubkey-only sshd)"
fi

# -----------------------------------------------------------------------------
# Section 14: claude-dashboard launcher (6-window monitoring tmux session)
# -----------------------------------------------------------------------------
# Typing 'claude-dashboard' builds (or attaches to) a separate tmux session
# named 'sessions' with six named windows:
#   home    - shell at /workspace/$USER
#   cluster - k9s pointed at the read-only kubeconfig
#   system  - htop
#   jobs    - journalctl -f on the claude-job@*.service units
#   docker  - oxker (containers, stats, logs, exec)
#   cheats  - tmux/Linux cheatsheet (pr -m -t side-by-side)
# The default auto-attach SSH session ('main') is untouched — only invoked
# when the operator explicitly runs claude-dashboard.
echo "==> [14/?] claude-dashboard launcher"

cat > /usr/local/bin/claude-dashboard <<'EOF'
#!/bin/bash
# Build (or attach to) the multi-window 'sessions' tmux session.
SESSION=sessions

# Backward compat: an earlier version of this launcher named the session
# 'dashboard'. If the old name still exists (and the new one doesn't),
# rename it in-place so the user keeps their state.
if tmux has-session -t dashboard 2>/dev/null && ! tmux has-session -t "$SESSION" 2>/dev/null; then
  tmux rename-session -t dashboard "$SESSION"
fi

if tmux has-session -t "$SESSION" 2>/dev/null; then
  exec tmux attach -t "$SESSION"
fi

# NB: `home` is a plain shell so typing `exit` closes it like any terminal.
# Every other long-lived window is wrapped in `while true; do CMD; sleep 0.5; done`
# so a quit in k9s/htop/journalctl rebuilds the view instead of killing the
# window (and shifting all the others by 1 because of renumber-windows on).
tmux new-session  -d -s "$SESSION" -n home -c "/workspace/$USER"
tmux new-window   -t "$SESSION:" -n cluster 'while true; do k9s --kubeconfig=$HOME/.kube/config 2>/dev/null || (echo "k9s unavailable; using watch fallback"; watch -n2 kubectl get pods -A); sleep 0.5; done'
tmux new-window   -t "$SESSION:" -n system  'while true; do htop; sleep 0.5; done'
tmux new-window   -t "$SESSION:" -n jobs    'while true; do journalctl -u "claude-job@*.service" -f --no-pager 2>/dev/null || sudo journalctl -f; sleep 0.5; done'
tmux new-window   -t "$SESSION:" -n docker  'while true; do oxker; sleep 0.5; done'
tmux new-window   -t "$SESSION:" -n cheats   'while true; do clear; pr -m -t -w $(tput cols) /usr/local/share/cheat-tmux.txt /usr/local/share/cheat-linux.txt | less -R; done'
tmux select-window -t "$SESSION:home"
exec tmux attach -t "$SESSION"
EOF
chmod 0755 /usr/local/bin/claude-dashboard

# Menu wrapper invoked by tmux's MouseDown1StatusLeft binding (status-left
# click). Enumerates current sessions and pops a display-menu — flat, no
# nested windows, no surprises. Selecting an entry runs switch-client.
cat > /usr/local/bin/tmux-session-menu <<'EOF'
#!/bin/bash
# Build a tmux display-menu listing all sessions; selecting one switches to it.
set -euo pipefail

# Each menu entry is three positional args: title, accelerator-key, command.
# We don't bother with accelerator keys; the user clicks or arrows.
ARGS=()
while IFS= read -r name; do
  ARGS+=("$name" "" "switch-client -t '$name'")
done < <(tmux list-sessions -F '#{session_name}' 2>/dev/null)

[ "$${#ARGS[@]}" -eq 0 ] && exit 0
exec tmux display-menu -T '#[align=centre]Sessions' -x M -y W "$${ARGS[@]}"
EOF
chmod 0755 /usr/local/bin/tmux-session-menu

# Cheat-sheet shown in the 6th dashboard window. Two narrow text files
# rendered side-by-side via `pr -m -t -w $(tput cols)` at view time, so the
# layout adapts to terminal width. Idempotent rewrite — edits here
# propagate on the next apply.
install -d -m 0755 /usr/local/share
cat > /usr/local/share/cheat-tmux.txt <<'CHEATEOF'
═══════════════════════════════════════════
  tmux  (prefix = Ctrl-b ≡ "C-b")
═══════════════════════════════════════════

── Sessions ──
  tmux ls          list sessions
  tmux a           attach (default)
  tmux a -t NAME   attach to specific
  C-b d            detach
  C-b s            pick session
  C-b $            rename session

── Windows (tabs) ──
  C-b c            new window
  C-b 0..9         jump to N
  C-b n / p        next / previous
  C-b l            toggle last
  C-b w            interactive picker
  C-b ,            rename window
  C-b &            kill window

── Panes (splits) ──
  C-b |            split horizontal
  C-b -            split vertical
  C-b h j k l      move between panes
  C-b H J K L      resize 5 cells
  C-b z            zoom toggle (full)
  C-b x            kill pane
  C-b space        cycle layouts
  C-b !            burst pane → window

── Copy mode (vi) ──
  C-b [            enter copy mode
  v                start selection
  y                yank + exit
  C-b ]            paste
  /  or  ?         search fwd / back
  n / N            next / prev match
  g  /  G          top / bottom
  q                exit

── Misc ──
  C-b r            reload ~/.tmux.conf
  C-b ?            list all bindings
  C-b t            big clock (cute)
  C-b :            command prompt

── This dashboard ──
  C-b 1            home   (shell)
  C-b 2            cluster (k9s)
  C-b 3            system (htop)
  C-b 4            jobs   (journalctl)
  C-b 5            docker (oxker)
  C-b 6            cheats (this page)
CHEATEOF
chmod 0644 /usr/local/share/cheat-tmux.txt

cat > /usr/local/share/cheat-linux.txt <<'CHEATEOF'
═══════════════════════════════════════════
  Linux essentials
═══════════════════════════════════════════

── Files ──
  ls -lah                 long, all, human
  find . -name '*.go' -mtime -7
  rg 'pattern'            ripgrep
  grep -RIn 'pat' .       recursive grep
  fzf                     fuzzy finder
  bat FILE                cat with colors

── Disk / IO ──
  df -h                   filesystems
  du -sh */               per-dir sizes
  lsblk                   block devices
  ncdu /workspace         disk usage TUI

── Process / system ──
  htop                    process TUI
  ps auxf                 full tree
  systemctl status NAME
  systemctl restart NAME
  journalctl -u NAME -f
  journalctl --since '1h ago' -p warning

── Network ──
  ss -tlnp                listening TCP + procs
  ip a                    interfaces
  curl -fsSL URL          silent fail-on-error
  curl -v URL             debug
  dig +short HOST         DNS lookup

── Text / streams ──
  head -20 / tail -20
  tail -f FILE            follow
  sed -i 's/a/b/g' FILE
  awk '{print $2}'
  cut -d: -f1
  sort | uniq -c | sort -rn
  tr A-Z a-z
  jq '.foo[]'             JSON
  yq '.foo.bar'           YAML

── Permissions / users ──
  chmod 0755 PATH
  chown user:group PATH
  id NAME / groups NAME
  sudo -u user CMD

── Compression / archives ──
  tar -xzf FILE.tar.gz
  tar -czf OUT.tar.gz DIR
  unzip FILE.zip
  zstd / unzstd

── Shell shortcuts (bash) ──
  Ctrl-R          history search
  Ctrl-A / Ctrl-E line start / end
  Ctrl-W          delete word back
  Ctrl-U          clear line
  !!  /  !$       last cmd / last arg
CHEATEOF
chmod 0644 /usr/local/share/cheat-linux.txt

# -----------------------------------------------------------------------------
# Section 15: weekly docker buildx prune (keep last 7 days of cache)
# Without this, /var/lib/containerd/io.containerd.snapshotter.v1.overlayfs grows
# unbounded as buildx caches pile up — easy to hit several GB in a single build.
# -----------------------------------------------------------------------------
echo "==> [15/?] docker-buildx-prune timer"

cat > /etc/systemd/system/docker-buildx-prune.service <<'EOF'
[Unit]
Description=Prune docker buildkit cache older than 7 days
Requires=docker.service
After=docker.service

[Service]
Type=oneshot
ExecStart=/usr/bin/docker buildx prune -f --filter=until=168h
EOF

cat > /etc/systemd/system/docker-buildx-prune.timer <<'EOF'
[Unit]
Description=Weekly docker buildx prune

[Timer]
OnCalendar=Sun 03:00
Persistent=true
Unit=docker-buildx-prune.service

[Install]
WantedBy=timers.target
EOF

systemctl daemon-reload
systemctl enable --now docker-buildx-prune.timer

echo "==> claude-worker bootstrap finished"
