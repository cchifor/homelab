# Local secrets / per-environment variables
*.tfvars
*.tfvars.bak.*
!terraform.tfvars.example
.env
.env.*
!.env.example

# OpenTofu / Terraform state and cache
*.tfstate
*.tfstate.*
.terraform/
crash.log
crash.*.log

# Fetched secrets (regenerated by null_resource on every bootstrap)
.k3s_token
kubeconfig

# Project-local helm repository cache (created by the helm provider — see providers.tf)
.helm/

# Editor / OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db

# Provider lockfile is intentionally COMMITTED:
#   .terraform.lock.hcl  <-- not ignored, that's the whole point of pinning

# Per-chart generated secrets (apps/charts/*-values/.secrets.env)
**/.secrets.env
